                            "url": "https://api-sandbox.fedpat.com.ar/documentacion-productos.html#tag/Producto/operation/getDatosParametricosPoliza"
                          },
                          "items": {
                            "type": "object",
                            "properties": {
                              "codigo": {
                                "type": "integer",
                                "description": "Codigo del dato",
                                "format": "int32"
                              },
                              "valor": {
                                "type": "string",
                                "description": "Valor del dato",
                                "nullable": true,
                                "externalDocs": {
                                  "description": "Los valores posibles pueden encontrarse aquí",
                                  "url": "https://api-sandbox.fedpat.com.ar/documentacion-productos.html#tag/Producto/operation/getOpciones_1"
                                }
                              }
                            },
                            "description": "Colección de Datos que pueden aplicar en la cotización realizada",
                            "externalDocs": {
                              "description": "Los datos existentes pueden encontrarse aquí",
                              "url": "https://api-sandbox.fedpat.com.ar/documentacion-productos.html#tag/Producto/operation/getDatosParametricosPoliza"
                            }
                          }
                        }
                      },
                      "description": "Coleccion de datos y coberturas de bienes asociado a la cotizacion",
                      "nullable": true
                    }
                  },
                  "fotos": {
                    "type": "array",
                    "description": "Fotos",
                    "nullable": true,
                    "items": {
                      "required": [
                        "foto"
                      ],
                      "type": "object",
                      "properties": {
                        "foto": {
                          "type": "string"
                        },
                        "nro_foto": {
                          "type": "integer",
                          "format": "int32",
                          "readOnly": true
                        },
                        "nombre": {
                          "type": "string",
                          "readOnly": true
                        }
                      },
                      "description": "Fotos"
                    }
                  },
                  "medio_pago": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Identificador del medio de pago.",
                        "format": "int32"
                      }
                    },
                    "description": "Medio de pago."
                  },
                  "contratante": {
                    "type": "object",
                    "properties": {
                      "matricula": {
                        "type": "string",
                        "description": "Identificación de un cliente existente dentro de Federación Patronal Seguros",
                        "example": "1125554"
                      }
                    },
                    "description": "Datos del contratante de la póliza (enviar en caso de no haber cotizado con un matriculado)"
                  },
                  "asegurado": {
                    "type": "object",
                    "properties": {
                      "tipo_matricula": {
                        "type": "string",
                        "description": "Identificación de un tipo cliente existente dentro de Federación Patronal Seguros",
