  "paths": {
    "/acreedores": {
      "get": {
        "tags": [
          "Emision automotores"
        ],
        "summary": "Obtiene los acreedores que se pueden agregar al momento de emitir automotores",
        "operationId": "obtenerAcreedores",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "codigo_acreedor": {
                        "type": "string"
                      },
                      "nombre_acreedor": {
                        "type": "string"
                      },
                      "domicilio": {
                        "type": "object",
                        "properties": {
                          "direccion": {
                            "type": "string"
                          },
                          "localidad": {
                            "type": "string"
                          },
                          "provincia": {
                            "type": "string"
                          },
                          "codigo_postal": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/emision-automotores/{cotizacion}": {
      "post": {
        "tags": [
          "Emision automotores"
        ],
        "summary": "Emisión de póliza de automotores.",
        "operationId": "emitirAutomotores",
        "parameters": [
          {
            "name": "cotizacion",
            "in": "path",
            "description": "Número de cotización a emitir",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "vehiculo"
                ],
                "type": "object",
                "properties": {
                  "vehiculo": {
                    "required": [
                      "chasis",
                      "destino",
                      "motor",
                      "patente"
                    ],
                    "type": "object",
                    "properties": {
                      "patente": {
                        "type": "string",
                        "description": "Número de DOMINIO o PATENTE del vehículo.",
                        "example": "XXX000"
                      },
                      "destino": {
                        "type": "string",
                        "description": "Código que representa el DESTINO del vehículo. \nLos valores permitidos son:\n* (1) PARTICULAR\n* (8) ESCOLAR Y SERV. ESPECIAL\n* (9) TRANSPORTE DE BIENES\n* (18) CARGAS PELIGROSAS\n* (19) SERVICIO ESPECIAL TRANSPORTE DE PASAJEROS\n* (21) COMERCIAL\n",
                        "example": "1",
                        "enum": [
                          "1",
                          "8",
                          "9",
                          "18",
                          "19",
                          "21"
                        ]
                      },
                      "motor": {
                        "maxLength": 25,
                        "minLength": 0,
                        "type": "string",
                        "description": "Número de MOTOR del vehículo.",
                        "example": "AAAA1111SSS222"
                      },
                      "chasis": {
                        "maxLength": 17,
                        "minLength": 0,
                        "type": "string",
                        "description": "Número de CHASIS del vehículo.",
                        "example": "BBXSBB111F1SSS222"
                      },
                      "ruta": {
                        "type": "string",
                        "description": "Número de RUTA. Se deberá completar si el vehículo lo requiere.",
                        "example": "00000000000"
                      },
                      "riesgo": {
                        "type": "string",
                        "description": "Detalle del RIESGO. Se deberá completar si el vehículo lo requiere.",
                        "example": "Mercedes Benz 190D"
                      },
                      "cerokm": {
                        "type": "boolean",
                        "description": "Indica si el vehículo es 0KM",
                        "example": false
                      }
                    }
                  },
                  "fotos": {
                    "type": "array",
                    "description": "Fotos",
                    "items": {
                      "required": [
                        "foto"
                      ],
                      "type": "object",
                      "properties": {
                        "foto": {
                          "type": "string"
                        },
                        "nro_foto": {
                          "type": "integer",
                          "format": "int32",
                          "readOnly": true
                        },
                        "nombre": {
                          "type": "string",
                          "readOnly": true
                        }
                      },
                      "description": "Fotos"
                    }
                  },
                  "medio_pago": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "Identificador del medio de pago.",
                        "format": "int32"
                      }
                    },
                    "description": "Medio de pago."
                  },
                  "contratante": {
                    "type": "object",
                    "properties": {
                      "matricula": {
                        "type": "string",
                        "description": "Identificación de un cliente existente dentro de Federación Patronal Seguros S.A.",
                        "example": "1125554"
                      }
                    },
                    "description": "Datos del contratante de la póliza (enviar en caso de no haber cotizado con un matriculado)"
                  },
                  "codigo_acreedor": {
                    "type": "integer",
                    "description": "Codigo del acreedor prendario",
                    "format": "int32"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Operacion exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sucursal": {
                      "type": "integer",
                      "format": "int32",
                      "readOnly": true
                    },
                    "cotizacion": {
                      "type": "integer",
                      "format": "int64",
                      "readOnly": true
                    },
                    "consecutivo": {
                      "type": "integer",
                      "format": "int32",
                      "readOnly": true
                    },
                    "ramo": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "poliza": {
                      "type": "integer",
                      "format": "int64"
                    },
                    "certificado": {
                      "type": "integer",
                      "format": "int32"
                    },
                    "productor": {
                      "type": "integer",
                      "format": "int32"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Datos de entrada inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": {
                      "type": "string"
                    },
                    "codigo_error": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciales inválidas, el token ingresado no es correcto",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": {
                      "type": "string"
                    },
                    "codigo_error": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Acceso restringido, no se poseen los permisos para acceder al recurso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": {
                      "type": "string"
                    },
                    "codigo_error": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Ocurrió un error inesperado al realizar la operación",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": {
                      "type": "string"
                    },
                    "codigo_error": {
                      "type": "string"
                    },
                    "time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/emision-otros-ramos/{cotizacion}": {
